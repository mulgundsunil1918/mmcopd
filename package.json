{
  "name": "curedesk-hms",
  "productName": "CureDesk HMS",
  "version": "0.4.0",
  "description": "OPD management software for Mulgund Multispeciality Clinic",
  "main": ".vite/build/main.js",
  "scripts": {
    "start": "electron-forge start",
    "package": "electron-forge package",
    "make": "electron-forge make",
    "publish": "electron-forge publish",
    "release": "npm version patch && git push --follow-tags && electron-forge publish",
    "build:demo": "vite build --config vite.demo.config.ts",
    "preview:demo": "vite preview --config vite.demo.config.ts",
    "make:installer": "electron-forge package && electron-builder --win nsis --x64 --prepackaged \"out/CureDesk HMS-win32-x64\"",
    "lint": "eslint --ext .ts,.tsx ."
  },
  "keywords": [],
